-- PRIMERA CONSULTA
Create View Consulta1
SELECT COUNT(*)
FROM Products p
INNER JOIN movement m
ON P.id = m.id_Product
GROUP BY (p.id, p.Name_Product)

-- SEGUNDA CONSULTA
CREATE VIEW consulta2
SELECT wh.name_WareHouse,m.Movement_type
FROM WareHouse wh
INNER JOIN movement m
ON wh.id = m.id_WareHouse
INNER JOIN Products P
ON m.id_Product = P.id
GROUP BY (wh.name_WareHouse,m.Movement_type)

-- TERCERA CONSULTA
CREATE VIEW consulta3
SELECT SUM(Quantity)
FROM Suppliers s
INNER JOIN movement m
ON s.id = m.id_supplier
GROUP BY (Name_Supplier)

-- CUARTA CONSULTA
CREATE VIEW consulta4
Select wh.Name_WareHouse
FROM WareHouse wh
INNER JOIN movement m
ON wh.id = m.id_WareHouse


