CREATE TABLE Suppliers (
    id SERIAL PRIMARY KEY,
    Name_Supplier VARCHAR(100) UNIQUE NOT NULL,
    Supplier_city VARCHAR(100)
);

CREATE TABLE WareHouse (
    id SERIAL PRIMARY KEY,
    Name_WareHouse VARCHAR(100) UNIQUE NOT NULL,
    WareHouse_city VARCHAR(100) UNIQUE NOT NULL
);
CREATE TABLE Products (
    id SERIAL PRIMARY KEY,
    Name_Product VARCHAR(100) UNIQUE NOT NULL,
    Category VARCHAR(100) 	
);

CREATE TABLE Movement (
    id SERIAL PRIMARY KEY,
	MovementDate VARCHAR (20), 
	id_Supplier int ,
    id_WareHouse int ,    
	id_Product int ,
	Quantity int  UNIQUE NOT NULL,
	UnitPrice int UNIQUE NOT NULL,
	Movement_type VARCHAR (10) ,
	PurchaseOrder VARCHAR (100) unique not null,	
    FOREIGN KEY (id_Supplier) REFERENCES Suppliers(id),
    FOREIGN KEY (id_WareHouse) REFERENCES WareHouse(id),
	FOREIGN KEY (id_Product) REFERENCES Products(id)
);

